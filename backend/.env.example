# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mockprep

# Database connection pool (per PM2 worker)
# With 4 workers x 20 connections = 80 total
# Ensure PostgreSQL max_connections >= 100
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# CORS — set to your frontend URL in production
CLIENT_ORIGIN=http://localhost:3000

# AWS
AWS_REGION=ap-south-1
S3_BUCKET=skilllens-documents

# SES (leave empty to skip emails in dev)
SES_FROM_EMAIL=
